---
import BitrixLayout from "../../layouts/BitrixLayout.astro";
---

<BitrixLayout title="Instalando Registros Retributivos">
  <main class="flex min-h-screen items-center justify-center bg-gray-100 p-6">
    <section class="max-w-lg rounded-2xl border border-gray-200 bg-white p-6 text-center shadow-sm">
      <p class="text-sm font-medium text-gray-500">Ponter · Bitrix</p>

      <h1 class="mt-2 text-2xl font-bold text-gray-950">
        Instalando Registros Retributivos
      </h1>

      <p class="mt-3 text-sm text-gray-600">
        Estamos finalizando la instalación de la aplicación local en Bitrix.
      </p>

      <div id="install-status" class="mt-5 rounded-xl bg-gray-50 p-4 text-sm text-gray-700">
        Inicializando Bitrix...
      </div>
    </section>
  </main>

  <script>
    function setStatus(message) {
      const node = document.getElementById("install-status");
      if (node) node.textContent = message;
    }

    document.addEventListener("DOMContentLoaded", function () {
      if (!window.BX24) {
        setStatus("BX24 no está disponible. Abre esta página desde Bitrix.");
        return;
      }

      window.BX24.init(function () {
        setStatus("Instalación completada. Abriendo la aplicación...");

        if (window.BX24.installFinish) {
          window.BX24.installFinish();
          return;
        }

        setStatus("No se encontró BX24.installFinish(). Revisa la configuración de la app.");
      });
    });
  </script>
</BitrixLayout>